# ============================================================
# Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values
#
# TWO WAYS TO CONFIGURE:
# 1. Use cfg.yml for config + env vars for secrets (recommended for development)
# 2. Use env vars only (good for production/containers)
# ============================================================

# -------------------- SECRETS (Required) --------------------

# Neo4j password (REQUIRED)
NEO4J_PASSWORD=your_neo4j_password_here

# PostgreSQL connection URL (REQUIRED)
# Format: postgresql://user:password@host:port/database
POSTGRES_URL=postgresql://user:password@localhost:5432/knowledge

# OpenAI API key (OPTIONAL)
# Only required if using OpenAI embeddings
OPENAI_API_KEY=your_openai_api_key_here

# -------------------- CONFIG (Optional) --------------------
# If cfg.yml doesn't exist, these env vars will be used for configuration
# Leave commented if using cfg.yml

# ENV=local
# LOG_LEVEL=INFO
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_DATABASE=neo4j
# POSTGRES_TABLE=embeddings