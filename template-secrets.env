# ============================================================
# Secrets
# ============================================================
# Copy this file to .env and fill in your actual values.
# Config (non-secret) values live in cfg.yml — do not add them here.
# ============================================================

# Graph backend — pick ONE of the two variants below.
#
# Variant A (commercial / ISO): full Neo4j URL with embedded creds.
#   Example: neo4j+s://user:pass@xxxxx.databases.neo4j.io:7687
GRAPH_URL=your_graph_url_here

# Variant B (defense): Amazon Neptune + OpenSearch Serverless.
# NEPTUNE_HOST and AOSS_HOST are non-secret endpoints — keep them in config.env,
# not here. Listed for documentation only:
#   NEPTUNE_HOST=your-neptune-endpoint.amazonaws.com
#   AOSS_HOST=your-aoss-endpoint.amazonaws.com

# PostgreSQL password (REQUIRED)
POSTGRES_PASSWORD=your_postgres_password_here

# OpenAI API key (REQUIRED for rag_search / combined_search)
OPENAI_API_KEY=your_openai_api_key_here
